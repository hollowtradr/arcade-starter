# Sticker Galaxy Arcade — Local Dev Environment
# Copy to .env and fill in your values.
#
# To get a dev session_token:
#   1. DM @hollowtradr on Telegram during studio onboarding
#   2. He'll run: uv run python -c "from app.api.arcade import issue_session_token; print(issue_session_token(<your_tg_id>, '<game_id>'))"
#   3. Paste the token below — valid for 60 minutes
#
# Without a token the game runs in demo mode (no real midi rewards).

# The Arcade API host. Production URL — don't change unless you're pointed at a fork.
VITE_ARCADE_API_URL=https://babyyoda-bot.fly.dev

# Your game's registered ID. "starter_dev" is the sandbox game for onboarding.
VITE_ARCADE_GAME_ID=swamp_runner

# Paste your dev session token here (leave blank for demo mode)
VITE_ARCADE_SESSION_TOKEN=
